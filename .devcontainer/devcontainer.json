{
	"name": "C Development",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools",
				"pkief.material-icon-theme",
				"bierner.markdown-mermaid"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.indentSize": 2,
				"editor.tabSize": 2
			}
		}
	},
	"remoteUser": "vscode"
}
